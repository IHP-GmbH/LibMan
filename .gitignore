# --- Build directories ---
build/
build-*/
cmake-build-*/
tests/build/
.deps/

# --- QtCreator / qmake project user files ---
*.pro.user
*.pro.user.*
*.pri.user
*.qbs.user
*.qmlproject.user
*.autosave

# --- Qt generated files (if they ever land in tree – usually in build dir) ---
moc_*.cpp
qrc_*.cpp
ui_*.h

# --- Compiler outputs ---
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib
*.exe
*.pdb

# --- Logs / temp ---
*.log
*.tmp
*.cache

# --- Doxygen output ---
docs/html/
docs/latex/
html/
latex/

# --- Cap'n Proto local build/install artifacts ---
capnp-install/
capnproto/build/

# --- Keep vendored Cap'n Proto sources ---
!capnproto/

# -------------------------------------------------
# Coverage (gcov / gcovr)
# -------------------------------------------------

# Main report
coverage.html
coverage.css
coverage.js

# Per-file html reports
coverage.*.html

# Raw coverage data
*.gcda
*.gcno
*.gcov

# Optional logs
test_results.txt
gcovr_verbose.txt