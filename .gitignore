# --- Build directories ---
build/
build-*/
cmake-build-*/
tests/build/
.deps/

# --- QtCreator / qmake project user files ---
*.pro.user
*.pro.user.*
*.pri.user
*.qbs.user
*.qmlproject.user
*.autosave

# --- Qt generated files (if they ever land in tree – usually in build dir) ---
moc_*.cpp
qrc_*.cpp
ui_*.h

# --- Compiler outputs ---
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib
*.exe
*.pdb

# --- Logs / temp ---
*.log
*.tmp
*.cache

# --- Doxygen output ---
docs/html/
docs/latex/
html/
latex/

# --- Cap'n Proto (fetched and built by libman.pro / tests.pro on first make) ---
capnproto/
capnp-install/

# -------------------------------------------------
# Coverage (gcov / gcovr)
# -------------------------------------------------

# Main report
coverage.html
coverage.css
coverage.js

# Per-file html reports
coverage*.html

# Raw coverage data
*.gcda
*.gcno
*.gcov

# Test / CI output
test_results*.txt
test_output.txt
coverage_by_file.txt
gcovr_verbose.txt

# Coverage output variants (for example coverage_test.css / coverage_test.js)
coverage*.css
coverage*.js
coverage*.txt