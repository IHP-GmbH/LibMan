{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "_stopLibMan",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "taskkill /IM libman.exe /F >nul 2>&1 || exit /b 0"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "hide": true
    },
    {
      "label": "_stopTests",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "taskkill /IM tst_libman_gui.exe /F >nul 2>&1 || exit /b 0"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "hide": true
    },
    {
      "label": "_configureLibMan",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-B",
        "build",
        "-G",
        "MinGW Makefiles",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_C_COMPILER=C:/Qt/Tools/mingw810_64/bin/gcc.exe",
        "-DCMAKE_CXX_COMPILER=C:/Qt/Tools/mingw810_64/bin/g++.exe",
        "-DCMAKE_MAKE_PROGRAM=C:/Qt/Tools/mingw810_64/bin/mingw32-make.exe",
        "-DCMAKE_PREFIX_PATH=C:/Qt/5.15.2/mingw81_64",
        "-DQt5_DIR=C:/Qt/5.15.2/mingw81_64/lib/cmake/Qt5"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$cmake",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "hide": true
    },
    {
      "label": "_configureTestsCoverage",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-B",
        "build",
        "-G",
        "MinGW Makefiles",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DLIBMAN_ENABLE_COVERAGE=ON",
        "-DCMAKE_C_COMPILER=C:/Qt/Tools/mingw810_64/bin/gcc.exe",
        "-DCMAKE_CXX_COMPILER=C:/Qt/Tools/mingw810_64/bin/g++.exe",
        "-DCMAKE_MAKE_PROGRAM=C:/Qt/Tools/mingw810_64/bin/mingw32-make.exe",
        "-DCMAKE_PREFIX_PATH=C:/Qt/5.15.2/mingw81_64",
        "-DQt5_DIR=C:/Qt/5.15.2/mingw81_64/lib/cmake/Qt5"
      ],
      "options": {
        "cwd": "${workspaceFolder}/tests"
      },
      "problemMatcher": "$cmake",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "hide": true
    },
    {
      "label": "Build LibMan",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "-j4"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "_stopLibMan",
        "_configureLibMan"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Run LibMan",
      "type": "shell",
      "command": "${workspaceFolder}/build/libman.exe",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/Qt/5.15.2/mingw81_64/bin;C:/Qt/Tools/mingw810_64/bin;${env:PATH}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Build Tests",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "-j4"
      ],
      "options": {
        "cwd": "${workspaceFolder}/tests"
      },
      "dependsOn": [
        "_stopTests",
        "_configureTestsCoverage"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": "$gcc",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "\"${workspaceFolder}\\scripts\\build_and_run_tests.bat\""
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/Qt/5.15.2/mingw81_64/bin;C:/Qt/Tools/mingw810_64/bin;${env:PATH}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
