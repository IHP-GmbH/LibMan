C {devices/code_shown.sym} 40 -1690 0 0 {name=SETUP only_toplevel=false value="* CACE gensim simulation file CACE\{filename\}_CACE\{N\}
* Generated by CACE gensim, Efabless Corporation (c) 2023
* Find the current through the amplifier under condition of static input

.include CACE\{DUT_path\}

.lib cornerMOSlv.lib CACE\{corner\}_mismatch
.lib cornerCAP.lib cap_typ

.option TEMP=CACE\{temperature\}
* Flag unsafe operating conditions (exceeds models' specified limits)
.option warn=1
"}
C {OTA1336.sym} 1680 -1040 0 0 {name=x1}
C {isource.sym} 1000 -650 0 0 {name=Ibias value="DC CACE\{Ibias\}"}
C {title-3.sym} 0 0 0 0 {name=l2 author="IHP-GmbH 2026" title="CACE input offset template " rev=1.0 lock=true}
C {devices/lab_pin.sym} 750 -620 0 0 {name=p1 sig_type=std_logic lab=VSUB}
C {devices/vsource.sym} 1220 -650 0 0 {name=Vvss value="DC CACE\{Vvss\}" savecurrent=false}
C {devices/lab_wire.sym} 1370 -1170 0 1 {name=p11 sig_type=std_logic lab=vdd}
C {devices/lab_wire.sym} 1370 -910 0 1 {name=p24 sig_type=std_logic lab=vss}
