value=CACE\{Rout\}
device=resistor}
C {devices/capa.sym} 2140 -1010 0 0 {name=Cout
value=CACE\{Cout\}}
C {devices/lab_pin.sym} 2180 -980 0 1 {name=p27 sig_type=std_logic lab=VSUB}
C {devices/vsource.sym} 770 -750 0 0 {name=Vvdd value="DC CACE\{Vvdd\}" savecurrent=false}
C {devices/code_shown.sym} 30 -1390 0 0 {name=CONTROL only_toplevel=false 
spice_ignore=true
value=".control
dc V2 -50m 50m 10u
meas dc Vout_at when out = CACE\{Vcm\}
let voffset = abs(2*Vout_at)
echo $&voffset  > CACE\{simpath\}/CACE\{filename\}_CACE\{N\}.data
quit
.endc
"}
C {devices/res.sym} 1070 -590 0 0 {name=RSUB
value=0.01
device=resistor}
C {devices/gnd.sym} 1070 -560 0 0 {name=l1 lab=GND}
C {devices/lab_pin.sym} 870 -1070 0 0 {name=p2 sig_type=std_logic lab=inp}
C {devices/lab_pin.sym} 1540 -1010 0 0 {name=p12 sig_type=std_logic lab=inm}
C {vsource.sym} 890 -670 0 0 {name=V2 value="DC 0.0"
}
C {vsource.sym} 890 -810 0 0 {name=V3 value="DC CACE\{Vcm\}" 
}
C {vsource.sym} 1410 -790 0 0 {name=V4 value="DC CACE\{Vcm\}" 
}
C {vcvs.sym} 1410 -710 0 0 {name=E1 value=-1}
C {devices/code_shown.sym} 30 -1200 0 0 {name=NGSPICE only_toplevel=false 
value="
.control
 
  let mc_runs = 10
  let run = 0
  set curplot=new          
  set scratch=$curplot    
  set appendwrite
  let voff=unitvec(mc_runs)
  
  
  dowhile run < mc_runs   
    reset
    dc V2 -50m 50m 10u
    meas dc Vin_at when out=0.6
    let Vin2_at = 2*$&Vin_at	    
    set run = $&run   
    set plt = $curplot          
    setplot $scratch       
    let voff[run]=\{$plt\}.Vin2_at
    setplot $plt
    let run = run + 1
    end  
* let mean_offset = mean(abs(\{$scratch\}.voff))
let max_offset = mean(abs(\{$scratch\}.voff)) +  3*stddev(\{$scratch\}.voff)

echo $&max_offset   > CACE\{simpath\}/CACE\{filename\}_CACE\{N\}.data
quit
.endc
"}
